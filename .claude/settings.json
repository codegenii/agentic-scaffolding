{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Read|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/hooks/worktree-path-guard.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python ./scripts/hooks/run-journal-subagent.py",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ./scripts/hooks/run-journal-subagent.py",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
